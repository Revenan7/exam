<Page x:Class="FootShop.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Товары"
      FontFamily="Times New Roman">

    <Grid Background="White">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Каталог товаров"
                   FontSize="26"
                   FontWeight="Bold"
                   Margin="0 20 0 10"
                   HorizontalAlignment="Center"/>

        <StackPanel Grid.Row="1"
                    x:Name="ControlPanel"
                    Orientation="Horizontal"
                    Margin="10"
                    HorizontalAlignment="Left">

            <TextBox x:Name="SearchBox"
                     Width="200"
                     Margin="0 0 10 0"
                     VerticalAlignment="Center"
                     TextChanged="SearchBox_TextChanged"/>

            <ComboBox x:Name="ProviderFilter"
                      Width="150"
                      Margin="0 0 10 0"
                      SelectionChanged="ProviderFilter_SelectionChanged"/>

            <ComboBox x:Name="SortBox"
                      Width="170"
                      SelectionChanged="SortBox_SelectionChanged">
                <ComboBoxItem Content="Без сортировки" />
                <ComboBoxItem Content="По возрастанию" />
                <ComboBoxItem Content="По убыванию" />
            </ComboBox>

        </StackPanel>

        <StackPanel Grid.Row="3"
                    x:Name="AdminPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">

            <Button x:Name="AddButton"
                    Content="Добавить товар"
                    Width="130"
                    Margin="5"
                    Background="#00FA9A"
                    Click="AddButton_Click"/>

            <Button x:Name="EditButton"
                    Content="Редактировать"
                    Width="130"
                    Margin="5"
                    Background="#00FA9A"
                    Click="EditButton_Click"/>

            <Button x:Name="DeleteButton"
                    Content="Удалить"
                    Width="130"
                    Margin="5"
                    Background="#FF6347"
                    Click="DeleteButton_Click"/>

        </StackPanel>

        <ListView Grid.Row="2"
                  x:Name="ProductsList"
                  Margin="10"
                  MouseDoubleClick="ProductsList_MouseDoubleClick">


            <ListView.ItemTemplate>
                <DataTemplate>

                    <Border BorderThickness="1"
                            BorderBrush="Black"
                            Padding="10"
                            Margin="5"
                            Height="200">

                        

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>

                            <Image Grid.Column="0"
                                   Width="140" Height="140"
                                   Source="/picture.png"/>

                            <StackPanel Grid.Column="1" Margin="10">

                                <TextBlock Text="{Binding ProductName}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding CategoryName}" FontStyle="Italic"/>

                                <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>

                                <TextBlock Text="Производитель:"/>
                                <TextBlock Text="{Binding ManufacturerName}"/>

                                <TextBlock Text="Поставщик:"/>
                                <TextBlock Text="{Binding ProviderName}"/>

                                <StackPanel Orientation="Horizontal">

                                    <TextBlock Text="{Binding Price}" Foreground="Red">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">

                                                <Style.Triggers>

                                                    <DataTrigger Binding="{Binding Discount}" Value="0">
                                                        <Setter Property="TextDecorations" Value="{x:Null}"/>
                                                    </DataTrigger>

                                                </Style.Triggers>

                                                <Setter Property="TextDecorations" Value="Strikethrough"/>

                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Text="{Binding FinalPrice}" Margin="10 0 0 0"/>

                                </StackPanel>

                                <TextBlock Text="Остаток:"/>
                                <TextBlock Text="{Binding QuantityInStock}"/>

                            </StackPanel>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Discount}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"/>

                        </Grid>

                    </Border>

                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </Grid>
</Page>
