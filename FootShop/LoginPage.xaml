<Page x:Class="FootShop.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FootShop"
      mc:Ignorable="d" 
      Title="LoginPage">

    <Grid Background="White">

        <TextBlock Text="Окно авторизации"
       FontSize="26"
       FontWeight="Bold"
       Margin="0 20 0 30"
       HorizontalAlignment="Center"/>


        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="250">

            <TextBlock Text="Логин" Margin="0 5 0 0"/>
            <TextBox x:Name="LoginBox" Height="30" Margin="0 5"/>

            <TextBlock Text="Пароль" Margin="0 5 0 0"/>
            <PasswordBox x:Name="PasswordBox" Height="30" Margin="0 5"/>

            <Button Content="Войти"
                Style="{StaticResource PrimaryButtonStyle}"
                Height="35" Margin="0 10 0 5"
                Background="#00FA9A"
                Click="Login_Click"/>

            <Button Content="Гостевой вход"
                Height="35"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="Guest_Click"/>

        </StackPanel>
    </Grid>
</Page>
