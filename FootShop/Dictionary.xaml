<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================== -->
    <!-- ЦВЕТА (меняйте только здесь!)                                   -->
    <!-- =============================================================== -->

    <!-- 1. Обычная кнопка -->
    <Color x:Key="ButtonPrimaryColor">#00FA9A</Color>
    <Color x:Key="ButtonPrimaryHoverColor">#00CE7D</Color>
    <Color x:Key="ButtonPrimaryPressedColor">#00B36B</Color>

    <!-- 2. Верхняя панель -->
    <Color x:Key="TopPanelColor">#7FFF00</Color>
    <Color x:Key="TopPanelTextColor">#000000</Color>

    <!-- 3. Кнопка удаления -->
    <Color x:Key="ButtonDeleteColor">#FF6347</Color>
    <Color x:Key="ButtonDeleteHoverColor">#E5533D</Color>
    <Color x:Key="ButtonDeletePressedColor">#CC4A36</Color>

    <!-- 4. Кнопка отмены -->
    <Color x:Key="ButtonCancelColor">#CCCCCC</Color>
    <Color x:Key="ButtonCancelHoverColor">#BFBFBF</Color>
    <Color x:Key="ButtonCancelPressedColor">#A8A8A8</Color>
    <Color x:Key="ButtonCancelTextColor">#212121</Color>

    <!-- Общие -->
    <Color x:Key="TextColor">Black</Color>
    <Color x:Key="BorderColor">Black</Color>


    <SolidColorBrush x:Key="ButtonPrimaryBrush" Color="{StaticResource ButtonPrimaryColor}"/>
    <SolidColorBrush x:Key="ButtonPrimaryHoverBrush" Color="{StaticResource ButtonPrimaryHoverColor}"/>
    <SolidColorBrush x:Key="ButtonPrimaryPressedBrush" Color="{StaticResource ButtonPrimaryPressedColor}"/>

    <SolidColorBrush x:Key="TopPanelBrush" Color="{StaticResource TopPanelColor}"/>
    <SolidColorBrush x:Key="TopPanelTextBrush" Color="{StaticResource TopPanelTextColor}"/>

    <SolidColorBrush x:Key="ButtonDeleteBrush" Color="{StaticResource ButtonDeleteColor}"/>
    <SolidColorBrush x:Key="ButtonDeleteHoverBrush" Color="{StaticResource ButtonDeleteHoverColor}"/>
    <SolidColorBrush x:Key="ButtonDeletePressedBrush" Color="{StaticResource ButtonDeletePressedColor}"/>

    <SolidColorBrush x:Key="ButtonCancelBrush" Color="{StaticResource ButtonCancelColor}"/>
    <SolidColorBrush x:Key="ButtonCancelHoverBrush" Color="{StaticResource ButtonCancelHoverColor}"/>
    <SolidColorBrush x:Key="ButtonCancelPressedBrush" Color="{StaticResource ButtonCancelPressedColor}"/>
    <SolidColorBrush x:Key="ButtonCancelTextBrush" Color="{StaticResource ButtonCancelTextColor}"/>

    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>

    <!-- 1. Обычная кнопка -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonPrimaryBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonPrimaryHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonPrimaryPressedBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- 2. Верхняя DockPanel-панель -->
    <Style x:Key="TopPanelStyle" TargetType="Grid">
        <Setter Property="Background" Value="{StaticResource TopPanelBrush}"/>
    </Style>

    <!-- Заголовок для панели (опционально) -->
    <Style x:Key="TopPanelTitleStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource TopPanelTextBrush}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="12,0"/>
    </Style>


    <!-- 3. Кнопка удаления -->
    <Style x:Key="DeleteButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonDeleteBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonDeleteHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonDeletePressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- 4. Кнопка отмены -->
    <Style x:Key="CancelButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource ButtonCancelBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource ButtonCancelTextBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonCancelHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource ButtonCancelPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>