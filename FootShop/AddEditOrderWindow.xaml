<Window x:Class="FootShop.AddEditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FootShop"
        mc:Ignorable="d"
        Title="Заказ"
        Height="420"
        Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>

            <TextBlock Text="Статус заказа"/>
            <ComboBox x:Name="StatusBox"
                      DisplayMemberPath="StatusName"
                      Margin="0 5"/>

            <TextBlock Text="Адрес пункта выдачи"/>
            <ComboBox x:Name="AddressBox"
                      DisplayMemberPath="AddressName"
                      Margin="0 5"/>

            <TextBlock Text="Дата заказа"/>
            <DatePicker x:Name="OrderDatePicker" Margin="0 5"/>

            <TextBlock Text="Дата доставки"/>
            <DatePicker x:Name="DeliveryDatePicker" Margin="0 5"/>

        </StackPanel>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 10">

            <Button Content="Сохранить"
                    Width="120"
                    Margin="5"
                    Click="Save_Click"/>

            <Button Content="Отмена"
                    Width="120"
                    Margin="5"
                    Click="Cancel_Click"/>

        </StackPanel>
    </Grid>
</Window>
